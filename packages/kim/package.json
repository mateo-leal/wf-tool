{
  "name": "@tenno-companion/kim",
  "version": "0.1.1",
  "keywords": [
    "warframe",
    "kim",
    "dialogue",
    "chatroom"
  ],
  "description": "Warframe KIM dialogue and chatroom data library for Tenno Companion",
  "repository": {
    "url": "github:mateo-leal/tenno-companion",
    "directory": "packages/kim"
  },
  "bugs": "https://github.com/mateo-leal/tenno-companion/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/lib/constants.d.ts",
      "import": "./dist/lib/constants.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "author": "Mateo Leal <me@mateoleal.com>",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm --filter @tenno-companion/core build",
    "check-updates": "tsx scripts/check-updates.ts",
    "fetch-data": "tsx scripts/fetch-data.ts",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest"
  },
  "dependencies": {
    "@tenno-companion/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
